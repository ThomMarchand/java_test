h1 {
  font-family: var(--font-primary);
  font-weight: var(--font-primary-800);
  font-size: 36px;
  letter-spacing: -1px;
}

h2 {
  font-family: var(--font-primary);
  font-weight: var(--font-primary-700);
  font-size: 24px;
  letter-spacing: -0.5px;
}

h3 {
  font-family: var(--font-primary);
  font-weight: var(--font-primary-700);
  font-size: 18px;
}